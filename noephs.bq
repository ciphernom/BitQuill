  "leaves": [
    {
      "document_state": {
        "content": "BitQuill is effectively someone trusted watching over your shoulder as you create a document. ",
        "system_time": 1745809981,
        "state_hash": "0026f3f1caf456c5e9e66441f30149d99f9ea69bd8b55e6683eb2d5fa57fadc3"
      },
      "vdf_tick_reference": 17,
      "prev_leaf_hash": "495d305616030969909813b15a5e76027e8be72c7fce382e278a6b1add553a7f",
      "timestamp": 1745809981,
      "hash": "135b444f3312ac2f5dbb40d14f706e4f5f191abc1ba949d7230964d7578b1a7b",
      "leaf_number": 1,
      "commitment": "0d03adfd9df01697df38fb8633b27d0ae67aa55e485a3a345a8af8ffd8ea9f35"
    },
    {
      "document_state": {
        "content": "It gives you the capacity, as the author, to prove you put time and effort into the creation of the document.",
        "system_time": 1745810000,
        "state_hash": "0acfb39cdf0d6a8fb048a42a1144fffa3e77f084c54a4c6dab85a390820182a0"
      },
      "vdf_tick_reference": 31,
      "prev_leaf_hash": "135b444f3312ac2f5dbb40d14f706e4f5f191abc1ba949d7230964d7578b1a7b",
      "timestamp": 1745810000,
      "hash": "ed68ec534152fe641cd85c9867cd3a1c1fb3aec488e2cffda8e4b6b981ac2a72",
      "leaf_number": 2,
      "commitment": "d206bd4ba660bddc8bdbb4788da0b4f9b7209e5204f92c343f84c613734fb1a9"
    },
    {
      "document_state": {
        "content": "It is impossible to forge a bitquill document, though someone might try to use an llm to generate paragraphs",
        "system_time": 1745810023,
        "state_hash": "cc199b018bf8d23dc23027340bec498a8a93247b66aff7d01dcba3f4ad00b02f"
      },
      "vdf_tick_reference": 48,
      "prev_leaf_hash": "ed68ec534152fe641cd85c9867cd3a1c1fb3aec488e2cffda8e4b6b981ac2a72",
      "timestamp": 1745810023,
      "hash": "236bb4353673602a326f78d6cb83575741b63cecb157e38cb97853ba37cf4d38",
      "leaf_number": 3,
      "commitment": "0e6455c9f9d4b78375c6644c6560aecec522184d896556c25c1ef06f39e170f1"
    },
    {
      "document_state": {
        "content": "This would be picked up by the forensic analysis verification.",
        "system_time": 1745810039,
        "state_hash": "643cb025b8bf89804f143c049fde41e4b76fdff53449378128623f97082a5102"
      },
      "vdf_tick_reference": 60,
