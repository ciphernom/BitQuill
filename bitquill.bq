  "leaves": [
    {
      "document_state": {
        "content": "The Challenge of Digital Authenticity",
        "system_time": 1746284487,
        "state_hash": "3bd93028101ca807710cf016a0da5c0ab3c78a5af96dafc26b702ad6ae2530e0"
      },
      "vdf_tick_reference": 14,
      "prev_leaf_hash": "495d305616030969909813b15a5e76027e8be72c7fce382e278a6b1add553a7f",
      "timestamp": 1746284487,
      "hash": "f744b03d546730b2f80238e80a93dbf5dca6b1a63efeb43cf6c2104021ecf000",
      "leaf_number": 1,
      "commitment": "3414aa6d60d7e733f4e9b40ed11fc3961921c591047c59cf2a67806766b09ac2"
    },
    {
      "document_state": {
        "content": "--------------------------------------",
        "system_time": 1746284491,
        "state_hash": "39a7b6780c7f9e4bd58fe4d77d0b34a0d3af011ded27337109873665643e36c5"
      },
      "vdf_tick_reference": 20,
      "prev_leaf_hash": "f744b03d546730b2f80238e80a93dbf5dca6b1a63efeb43cf6c2104021ecf000",
      "timestamp": 1746284491,
      "hash": "a67de0a23a79283e2c9dff90bfc2f826fda9cc0a72e3428d8fe0cec0fd446615",
      "leaf_number": 2,
      "commitment": "e5522875f19b94906dcccbb20aac0dae7b0452b6d84f6243b431f4c623ba4c55"
    },
    {
      "document_state": {
        "content": "In today's world, we face an unprecedented challenge: how can we prove digital documents are genuine, human-authored works?",
        "system_time": 1746284514,
        "state_hash": "210887f3674d813bf925d6234c853f42ee77c61ae523dadf487435ff67c70678"
      },
      "vdf_tick_reference": 52,
      "prev_leaf_hash": "a67de0a23a79283e2c9dff90bfc2f826fda9cc0a72e3428d8fe0cec0fd446615",
      "timestamp": 1746284514,
      "hash": "d82a6980c4022b9f1edf891649c23f26c0825d70b830b046689bf3dcfd193618",
      "leaf_number": 3,
      "commitment": "cbde4e2de85366965b59d1903c9a050aa2bb88b078eb19075997bc7f852cc2ee"
    },
    {
      "document_state": {
        "content": "",
        "system_time": 1746284514,
        "state_hash": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
      },
      "vdf_tick_reference": 53,
      "prev_leaf_hash": "d82a6980c4022b9f1edf891649c23f26c0825d70b830b046689bf3dcfd193618",
      "timestamp": 1746284514,
      "hash": "11a3b73cf903ef2cce4260707c8c3eb31b56d968b3e79e3bb329ccad1f1d1e5e",
      "leaf_number": 4,
      "commitment": "a7a2e33c708c19510df8667d1ce5eb21d0499f6ba00262cbd138cf77e2929904"
    },
    {
      "document_state": {
        "content": "Throughout history, the integrity of written information has been safeguarded by physical properties and social conventions - the texture of papyrus, ",
        "system_time": 1746284547,
        "state_hash": "92aac8b2c6fe367778216a91ae7094cfc41e1196a8572a76251813190cc21d78"
      },
      "vdf_tick_reference": 101,
      "prev_leaf_hash": "11a3b73cf903ef2cce4260707c8c3eb31b56d968b3e79e3bb329ccad1f1d1e5e",
      "timestamp": 1746284547,
      "hash": "5fc107a934e5e57b1b562d92b4ed47fb827e1e672441df0065d24499dbf36ab6",
      "leaf_number": 5,
      "commitment": "96903f95ab49e1adf3ea1f9bf02327d7dcef8c70f8350e7f3384f8968eb7e4fc"
    },
    {
      "document_state": {
        "content": "the mark of seals, the flow of ink. These physical constructs formed the bedrock of trust in written records for millenia. ",
        "system_time": 1746284567,
        "state_hash": "3f0998fa73f45dde3c8450d6d254c7cd9af5f9ce01fcb9254e26d88795b8a16e"
      },
      "vdf_tick_reference": 130,
      "prev_leaf_hash": "5fc107a934e5e57b1b562d92b4ed47fb827e1e672441df0065d24499dbf36ab6",
      "timestamp": 1746284567,
      "hash": "f824993587147f1ef3889af05c4c4ea531a370a9e8654c884bfa788875e78cfd",
      "leaf_number": 6,
      "commitment": "88c2cfbe63a5b71aa16528fc8cb9503e3c8783c61b1aee38bb8fb21b0425e186"
    },
    {
      "document_state": {
        "content": "",
        "system_time": 1746284568,
        "state_hash": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
      },
      "vdf_tick_reference": 131,
      "prev_leaf_hash": "f824993587147f1ef3889af05c4c4ea531a370a9e8654c884bfa788875e78cfd",
      "timestamp": 1746284568,
      "hash": "3d45e2af0a7c1055c60e56dcd47b57ea282ce54769d05eba0377baafe4cc5277",
      "leaf_number": 7,
      "commitment": "6437fff8389613afd167bd8429c7b0c6394911423cce3be702a8c4a78e64420f"
    },
    {
      "document_state": {
        "content": "Digitisation has stripped away these inherent security properites. With the rapid rise of Large Language Models capable of producing increasingly convincing",
        "system_time": 1746284602,
        "state_hash": "593a090e58a22001db40b2ad3df691e86e5b428d6f4c1b232fc8dd17a052bf7b"
      },
      "vdf_tick_reference": 179,
      "prev_leaf_hash": "3d45e2af0a7c1055c60e56dcd47b57ea282ce54769d05eba0377baafe4cc5277",
      "timestamp": 1746284602,
      "hash": "0f1d64f1463bf40659496a310a83df678cc74f8a5b36e898935057fa70189cc9",
      "leaf_number": 8,
      "commitment": "fc1f38ae358bbf0a390385f3309aa53d46f87c229acfc0780bd44c9a59edbe5f"
    },
    {
      "document_state": {
        "content": "text, we need new methods to verify human authorship.",
        "system_time": 1746284618,
        "state_hash": "32372ecaf3c9744e802fe6400f730b7633a6dacdc505c32a0f303bb793db1291"
      },
      "vdf_tick_reference": 202,
      "prev_leaf_hash": "0f1d64f1463bf40659496a310a83df678cc74f8a5b36e898935057fa70189cc9",
      "timestamp": 1746284618,
      "hash": "863f58bbaf2e4aa98d9d0523fe55770bdb24fd508460e6f3bd5118299fcb9b6b",
      "leaf_number": 9,
      "commitment": "7f936a16d1c9840df00c00c99c04327cb194d36f0adba3f0385ee405d24f0746"
    },
    {
      "document_state": {
        "content": "",
        "system_time": 1746284618,
        "state_hash": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
      },
      "vdf_tick_reference": 203,
      "prev_leaf_hash": "863f58bbaf2e4aa98d9d0523fe55770bdb24fd508460e6f3bd5118299fcb9b6b",
      "timestamp": 1746284618,
      "hash": "23aeea39af935c53b8ce92b61fc471b20e89812d2a942fc373856d502510ad81",
      "leaf_number": 10,
      "commitment": "bd2b747df289414354e12e02506b06764f856bfa5c4fb416821a450807c5a29e"
    },
    {
      "document_state": {
        "content": "BitQuill - a digital witness to human creation",
        "system_time": 1746284629,
        "state_hash": "3dc84865f66546001854414fd96ec693189ca67c2171171e88ceac2e442f81c3"
      },
      "vdf_tick_reference": 218,
      "prev_leaf_hash": "23aeea39af935c53b8ce92b61fc471b20e89812d2a942fc373856d502510ad81",
      "timestamp": 1746284629,
      "hash": "ccbd02f3153d8cad46448e7cdb25fa297dcee2f11fa485c675a7defdf8fc9789",
      "leaf_number": 11,
      "commitment": "a0323d27f46b1c37b5173b9c2740d78ae45fce1764ca1c77079456a2c29136ca"
    },
    {
      "document_state": {
        "content": "By giving the author the capacity to show a digital sweat equity - i.e. that they have put time and effort into a particular document",
        "system_time": 1746284655,
        "state_hash": "5a7667dd71367f4571bcbc576da6ca7dbac773bbd090e655c98d53c399c50855"
      },
      "vdf_tick_reference": 256,
      "prev_leaf_hash": "ccbd02f3153d8cad46448e7cdb25fa297dcee2f11fa485c675a7defdf8fc9789",
      "timestamp": 1746284655,
      "hash": "4fad3a75a6d0042ef9a590039d9685e30537ed7acdca48a70416559d16e8c1cd",
      "leaf_number": 12,
      "commitment": "bef03b3b1cc0829eeaaa9f542e24689058a20c746f2a52202e8443dd7cfbea02"
    },
    {
      "document_state": {
        "content": "we reclaim some of this trust. ",
        "system_time": 1746284663,
        "state_hash": "f1b952165d4fff1568d0c44e6540b54ac04dfb730cc4fe445e1ac7857ad7576f"
      },
      "vdf_tick_reference": 267,
      "prev_leaf_hash": "4fad3a75a6d0042ef9a590039d9685e30537ed7acdca48a70416559d16e8c1cd",
      "timestamp": 1746284663,
      "hash": "f93b05c149933487f86f5996cf38d7ef65c4a4ec71721e70d56cc900cb399a46",
      "leaf_number": 13,
      "commitment": "bae19f05bbbfb7e48ee062b7222a0b21e36948c033c9ab97f514bd112a3b0a8a"
    }
  ],
